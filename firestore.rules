rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isValidEmployee(data) {
      return data.employeeId is string && data.employeeId.size() > 0 &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.team is string && data.team.size() > 0;
    }
    
    function isValidAttendance(data) {
      return data.employeeId is string &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             data.status in ['present', 'absent', 'late', 'half-day', 'off'] &&
             (data.workContent == null || data.workContent is string) &&
             (data.proofUrl == null || data.proofUrl is string) &&
             (data.sxkd == null || data.sxkd is bool) &&
             (data.luuDong == null || data.luuDong is bool) &&
             (data.thueXe == null || data.thueXe is bool) &&
             (data.atd == null || data.atd is bool) &&
             (data.confirmed == null || data.confirmed is bool);
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
         request.auth.token.email == "hinhanhtramcongcong@gmail.com");
    }

    function isEditor() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
         request.auth.token.email == "hinhanhtramcongcong@gmail.com");
    }

    match /employees/{employeeId} {
      allow read: if isEditor();
      allow write: if isAdmin();
    }

    match /attendance/{recordId} {
      allow read: if isEditor();
      allow write: if isEditor();
    }

    match /admins/{adminId} {
      allow read: if isEditor();
      allow write: if isAdmin();
    }

    // Allow connection test
    match /_connection_test_/{docId} {
      allow read: if true;
    }
  }
}
